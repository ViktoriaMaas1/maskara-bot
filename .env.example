# ============================================================
# MASKARA AI Trading Bot — Configuration Template
# ============================================================
# ИНСТРУКЦИЯ:
#   1. Скопируй этот файл:   cp .env.example .env
#   2. Заполни значения ниже
#   3. .env НИКОГДА не коммитится в git (он в .gitignore)
#
# Stage 1 требует только секции [APP], [WEBHOOK], [POSTGRES], [REDIS].
# Остальные нужны для следующих этапов — оставь как есть, заполнишь позже.
# ============================================================


# ============================================================
# [APP] — общие настройки приложения
# ============================================================

# Окружение: development | testnet | production
# В Stage 1-14 разрешён только testnet или development.
# production разблокируется только после прохождения 100+ testnet сделок.
APP_ENV=development

# Уровень логов: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Порт FastAPI (наружу)
API_PORT=8000


# ============================================================
# [WEBHOOK] — приём сигналов от TradingView
# ============================================================

# Секретный токен — TradingView должен присылать его в JSON.
# Сгенерируй случайный, например:  openssl rand -hex 32
# НЕ используй пример ниже в проде!
WEBHOOK_SECRET=CHANGE_ME_to_a_long_random_string_at_least_32_chars

# Разрешённые символы (через запятую, без пробелов).
# Webhook отвергнет сигнал по любому другому символу.
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT

# Rate limit: максимум сигналов с одного IP в минуту
WEBHOOK_RATE_LIMIT_PER_MIN=30

# TTL дедупликации: одинаковый сигнал в течение N секунд игнорируется
WEBHOOK_DEDUP_TTL_SEC=10


# ============================================================
# [POSTGRES] — журнал сделок, AI memory
# ============================================================

POSTGRES_USER=maskara
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=maskara_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432


# ============================================================
# [REDIS] — кэш, rate limit, дедупликация
# ============================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_DB=0


# ============================================================
# [BYBIT] — биржа (заполнить в Stage 2)
# ============================================================

# КРИТИЧНО: только TESTNET до прохождения тестов!
BYBIT_TESTNET=true

# Получи на testnet.bybit.com → Account → API → Create API Key
BYBIT_API_KEY=
BYBIT_API_SECRET=


# ============================================================
# [TELEGRAM] — уведомления (заполнить в Stage 4)
# ============================================================

# 1. В Telegram найди @BotFather → /newbot → получишь токен
# 2. Найди @userinfobot → пришлёт твой chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ============================================================
# [EXTERNAL DATA] — внешние API (заполнить в Stage 9)
# ============================================================

# CoinGlass — liquidation heatmap, OI, funding, long/short ratio
COINGLASS_API_KEY=

# News — например, cryptopanic.com, newsapi.org (выберем в Stage 9)
NEWS_API_KEY=
BYBIT_READONLY_MODE=true
